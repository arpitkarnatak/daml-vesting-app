# ---- Backend HTTP ----
PORT=3001

# ---- Canton JSON Ledger API (v2) ----
# Base URL of the participant's JSON Ledger API.
# dpm sandbox default: http://localhost:6864
# classic Canton sandbox default: http://localhost:7575
# cn-quickstart AppUser validator: http://localhost:2975
LEDGER_JSON_API_URL=http://localhost:6864

# The user/application id used on submitted commands (must match the token's subject
# when auth is enabled). For an unauthenticated sandbox any value works.
LEDGER_USER_ID=vesting-app

# Package-name reference used to build template ids: "#<daml-package-name>".
# Your daml.yaml names the package "vesting", so template ids look like
#   #vesting:VestingAgreement:VestingProposal
PACKAGE_REF=#vesting

# ---- Auth ----
# false  -> no Authorization header sent (unauthenticated local sandbox)
# true   -> fetch an OAuth2 client-credentials token and send it as a Bearer token
AUTH_ENABLED=false

# Only used when AUTH_ENABLED=true (values below are the cn-quickstart LocalNet defaults)
OAUTH_TOKEN_URL=http://keycloak.localhost:8082/realms/AppUser/protocol/openid-connect/token
OAUTH_CLIENT_ID=app-user-validator
OAUTH_CLIENT_SECRET=6m12QyyGl81d9nABWQXMycZdXho6ejEX
OAUTH_SCOPE=openid
